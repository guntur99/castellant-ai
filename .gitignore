# Rust-related ignores
/target/
**/*.rs.bk
Cargo.lock

# Environment variables (Crucial for security)
.env
.env.*

# OS-generated files
.DS_Store
Thumbs.db

# IDEs/Editors
.vscode/
.idea/
*.swp
*.swo

# Project specific
/static/uploads/*
!/static/uploads/.gitkeep
# Ensure base assets ARE tracked
!/static/img/*
!/static/css/*
!/static/js/*
